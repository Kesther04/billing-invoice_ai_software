generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}


// ─── Enums ────────────────────────────────────────────────────────────────────

enum InvoiceStatus {
  draft
  pending
  paid
  overdue
  cancelled
}

enum InvoiceSource {
  manual
  ai
}

enum OrganizationType {
  ORGANIZATION
  INDIVIDUAL
}

enum UserRole {
  OWNER     // Individual account owner
  ADMIN     // Creator of an organization
  MEMBER    // Invited team member
}

model Organization {
  id        String           @id @default(uuid())
  name      String
  email     String           @unique
  type      OrganizationType
  inviteCode String?          @unique
  createdAt DateTime         @default(now())

  clients   Client[]
  invoices  Invoice[]
  users     User[]
  // ← Add this back-relation (optional since organizationId? in token)
  passwordResetTokens PasswordResetToken[]
}

model User {
  id             String       @id @default(uuid())
  name           String
  email          String       @unique
  password       String
  role           UserRole
  organizationId String
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  // ← Add this back-relation
  passwordResetTokens PasswordResetToken[]
  invoices       Invoice[]
}

model PasswordResetToken {
  id             String       @id @default(uuid())
  token          String       @unique
  userId         String
  organizationId String?
  expiresAt      DateTime
  usedAt         DateTime?
  createdAt      DateTime     @default(now())

  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ─── Client ───────────────────────────────────────────────────────────────────

model Client {
  id             String   @id @default(uuid())
  name           String
  email          String?
  company        String?
  phone          String?
  address        String?
  organizationId String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  invoices     Invoice[]
}

// ─── Invoice ──────────────────────────────────────────────────────────────────

model Invoice {
  id             String        @id @default(uuid())
  invoiceNumber  String        @unique
  status         InvoiceStatus @default(draft)
  source         InvoiceSource @default(manual) // tracks whether AI or manual

  // Parties stored as JSON (flexible — matches frontend InvoiceParty type)
  fromParty      Json          // { name, email, address, phone, company }
  toParty        Json          // { name, email, address, phone, company }

  issueDate      DateTime
  dueDate        DateTime

  // Financials
  subtotal       Float         @default(0)
  taxRate        Float         @default(0)
  taxAmount      Float         @default(0)
  discountAmount Float         @default(0)
  total          Float         @default(0)
  currency       String        @default("USD")

  notes          String?

  // AI metadata (null when source = manual)
  aiPrompt       String?       // the original prompt used
  aiConfidence   Float?        // confidence score from AI parser
  aiSuggestions  Json?         // array of string suggestions

  // Relations
  organizationId String
  clientId       String?       // optional — client may not exist in DB yet
  createdById    String?       // user who created it

  organization Organization @relation(fields: [organizationId], references: [id])
  client       Client?      @relation(fields: [clientId], references: [id])
  createdBy    User?        @relation(fields: [createdById], references: [id])

  lineItems    LineItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizationId])
  @@index([status])
  @@index([dueDate])
  @@index([clientId])
}

// ─── LineItem ─────────────────────────────────────────────────────────────────

model LineItem {
  id          String  @id @default(uuid())
  invoiceId   String
  description String
  quantity    Float
  unitPrice   Float
  total       Float

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}
